# Java / Spring Boot
# 说明：忽略 Maven 构建产物和本地运行日志。
target/
*.class
*.jar
*.war
*.log

# Node / Vue
# 说明：忽略依赖目录、Vite 构建输出和缓存。
node_modules/
dist/
.vite/

# IDE
# 说明：忽略本地编辑器工程配置。
.idea/
.vscode/
*.iml

# Environment
# 说明：忽略本地环境变量和覆盖配置，避免提交真实密码或个人路径。
.env
.env.*
application-local.yml
application-dev.yml

# OS
# 说明：忽略操作系统生成的临时元数据。
.DS_Store
Thumbs.db

# Uploaded files / local data
# 说明：忽略本地上传文件、临时存储和压缩包。
uploads/
local-storage/
*.zip
*.rar
*.7z

# Sensitive or large files
# 说明：忽略模型权重、数据集、运行输出和论文资料等大文件。
*.pt
*.pth
*.onnx
*.engine
datasets/
weights/
runs/
paper/
